{
	"name": "deepseek-copilot",
	"publisher": "ChenyuHeee",
	"displayName": "DeepSeek for GitHub Copilot Chat",
	"description": "Integrates DeepSeek V4 Flash and V4 Pro into GitHub Copilot Chat",
	"icon": "assets/logo.png",
	"repository": {
		"type": "git",
		"url": "https://github.com/ChenyuHeee/deepseek-copilot"
	},
	"version": "0.2.0",
	"engines": {
		"vscode": "^1.104.0"
	},
	"categories": [
		"AI",
		"Chat"
	],
	"galleryBanner": {
		"color": "#100f11",
		"theme": "dark"
	},
	"bugs": {
		"url": "https://github.com/ChenyuHeee/deepseek-copilot/issues"
	},
	"license": "MIT",
	"contributes": {
		"languageModelChatProviders": [
			{
				"vendor": "huggingface",
				"displayName": "DeepSeek V4 Pro",
				"managementCommand": "huggingface.manage"
			}
		],
		"commands": [
			{
				"command": "huggingface.manage",
				"title": "Manage DeepSeek V4 Pro Provider"
			}
		]
	},
	"main": "./out/extension.js",
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -p ./",
		"watch": "tsc -watch -p ./"
	},
	"dependencies": {},
	"devDependencies": {
		"@types/node": "^22",
		"@vscode/dts": "^0.4.1",
		"@types/vscode": "^1.103.0",
		"typescript": "^5.9.2"
	}
}
